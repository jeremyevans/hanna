source 'https://rubygems.org'

gem 'rake'
gem 'minitest-hooks'
gem 'minitest-global_expectations'

gem "psych", "= 3.0.2" if RUBY_VERSION[0..2] == "2.5"

if RUBY_VERSION <= '2.7'
  gem 'rdoc', '< 6.4'
else
  gem 'rdoc'
end

platforms :jruby do
  if RUBY_VERSION >= '2.6'
    if RUBY_VERSION < '2.7'
      gem 'erb', '< 4'
    end
    gem 'jar-dependencies', '0.4.1'
  end
end
